{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/inject-memory.mjs", "--mode=${user_config.memory_loader_mode}"],
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/inject-memory.mjs", "--mode=${user_config.memory_loader_mode}"],
            "timeout": 10
          }
        ]
      }
    ]
  }
}
